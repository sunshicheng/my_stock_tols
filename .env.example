# DeepSeek API 配置
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 调度时间（24小时制 HH:MM）
PREDICT_TIME=08:30
REVIEW_TIME=16:30

# Web 后端（可选）
# WEB_SECRET_KEY=your-jwt-secret-change-in-production

# 慢速拉取（减轻限流，默认开启；设为 false 可加快速度但更容易被限流）
SLOW_FETCH=true
FETCH_INTERVAL_API=1.0
FETCH_INTERVAL_STOCK=0.5
FETCH_INTERVAL_NEWS=1.2
